---
import Layout from '../layouts/Layout.astro';
import { Reveal } from '../components/Reveal';

const title = "Miro Kloosterman — Private retreats and integrated healing";
const description = "Private retreats, breathwork, bodywork, and integrated healing with Miro Kloosterman. Nine modalities, one practitioner, one room that feels safe.";
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="relative h-screen flex items-center px-section-x pt-24 overflow-hidden grain bg-deep-forest">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://picsum.photos/seed/miro-bali-hero/1920/1080" 
        alt="Miro in Bali" 
        class="object-cover w-full h-full opacity-50"
        referrerpolicy="no-referrer"
      />
      <div class="absolute inset-0 bg-deep-forest/40"></div>
    </div>
    
    <div class="max-w-7xl mx-auto w-full z-10">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label !text-gold">Body, Mind & Soul Therapy</span>
          <h1 class="text-white mb-8">Miro Kloosterman</h1>
          <p class="font-body text-xl md:text-2xl font-light text-sand/80 mb-8 tracking-wide">
            Retreat facilitator. Breathwork therapist. Healer.
          </p>
          <p class="text-sand/60 text-lg max-w-xl mb-12 font-light">
            I spent five years rebuilding my life from the foundation up after burnout and chronic illness. Now, I help others find their way back to themselves in the same room where I found my own healing.
          </p>
          <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Free Discovery Call</a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — The Story Hook -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-4xl mx-auto text-center">
      <Reveal client:load>
        <blockquote class="mb-12">
          <p class="font-display text-4xl md:text-6xl text-deep-forest leading-tight italic">
            "Some people say you never fully recover. I was going to prove them wrong."
          </p>
        </blockquote>
        <p class="font-body text-xs font-bold uppercase tracking-[2px] text-sage mb-12">
          Miro Kloosterman, Story Magazine 2026
        </p>
        <div class="max-w-2xl mx-auto text-lg text-charcoal/80 mb-12 font-light leading-relaxed">
          <p>The journey from a high-pressure acting career to a life of deep service wasn't a choice—it was a necessity. It was the only way to survive the collapse of a body and mind that had been pushed too far for too long.</p>
        </div>
        <a href="/about" class="btn-text">Read Miro's full story →</a>
      </Reveal>
    </div>
  </section>

  <!-- Section 3 — What Brings You Here -->
  <section class="bg-deep-forest py-section-y px-section-x grain">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
      <Reveal client:load>
        <h2 class="text-white mb-12">You don't have to walk this path alone.</h2>
        <p class="text-sand/60 text-lg font-light leading-relaxed max-w-xl">
          Healing isn't about collecting modalities. It's about finding the specific key that unlocks your unique system. Whether you're facing the wall of burnout or the weight of old grief, we meet it together with presence and precision.
        </p>
      </Reveal>
      <Reveal client:load delay={0.2}>
        <div class="flex flex-wrap gap-4">
          {[
            "Burnout & Exhaustion",
            "Chronic Pain",
            "Stored Trauma",
            "Grief & Loss",
            "Emotional Disconnection",
            "Performance Pressure",
            "Lyme Disease Recovery",
            "Spiritual Crisis"
          ].map(item => (
            <span class="px-6 py-3 bg-sand text-sage font-body text-xs font-bold uppercase tracking-[1px]">
              {item}
            </span>
          ))}
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 4 — The Practice -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <Reveal client:load>
        <span class="label">The Practice</span>
        <h2 class="mb-24 max-w-3xl">A tailor-made strategy. No two people the same.</h2>
      </Reveal>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {[
          { name: "Private Retreats", desc: "A fully immersive, one-on-one healing journey in Bali.", href: "/retreats/private" },
          { name: "Breathwork", desc: "Deep somatic release using the power of conscious breathing.", href: "/sessions/breathwork" },
          { name: "Body Reset", desc: "Manual therapy to realign the physical and energetic body.", href: "/sessions/body-reset" },
          { name: "Chi Core Massage", desc: "Abdominal work to release stored emotional tension.", href: "/sessions/chi-nei-tsang" },
          { name: "Water Therapy", desc: "Aquatic healing for deep nervous system regulation.", href: "/sessions/water-therapy" },
          { name: "Hypnotherapy", desc: "Subconscious reprogramming for lasting habit change.", href: "/sessions/hypnotherapy" }
        ].map((service, i) => (
          <Reveal client:load delay={i * 0.1} className="h-full">
            <a href={service.href} class="service-card group h-full">
              <h3 class="text-white group-hover:text-gold transition-colors">{service.name}</h3>
              <p class="text-sand/60 font-light text-sm leading-relaxed">{service.desc}</p>
              <span class="btn-text !text-gold mt-auto">Explore →</span>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 5 — Social Proof -->
  <section class="bg-sand py-section-y px-section-x overflow-hidden">
    <div class="max-w-7xl mx-auto">
      <Reveal client:load>
        <span class="label">What Clients Say</span>
        <h2 class="mb-8">Voices of Transformation.</h2>
        <p class="text-lg font-light text-charcoal/60 max-w-2xl mb-16">
          The true measure of this work isn't found in the modalities themselves, but in the quiet shifts and profound breakthroughs of those who walk through the door.
        </p>
      </Reveal>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-24 gap-y-16">
        <Reveal client:load>
          <div class="pull-quote">
            "What I experienced with Miro was beyond any description. Like I'm leaving my body and then coming back again but as a different person. It really feels like a rebirth."
          </div>
          <p class="font-body text-xs font-bold uppercase tracking-[2px] text-charcoal/40 mt-6">Christopher · Breathwork</p>
        </Reveal>
        
        <Reveal client:load delay={0.1}>
          <div class="pull-quote">
            "After only one session, years of neck and shoulder tension was all gone. I finally feel like I can breathe again."
          </div>
          <p class="font-body text-xs font-bold uppercase tracking-[2px] text-charcoal/40 mt-6">Anna · Body Reset</p>
        </Reveal>

        <Reveal client:load delay={0.2}>
          <div class="pull-quote">
            "During the first session I experienced the most intense crying in my whole life. It was grief of being a vanished twin. After this session I can say that my life shifted completely."
          </div>
          <p class="font-body text-xs font-bold uppercase tracking-[2px] text-charcoal/40 mt-6">Maria Johanna · Chi Core Release</p>
        </Reveal>

        <Reveal client:load delay={0.3}>
          <div class="pull-quote">
            "You are someone with a huge passion for his profession and a great love for his coachees. I recognize myself very well in your metaphor of the butterfly. Time to shine, Miro."
          </div>
          <p class="font-body text-xs font-bold uppercase tracking-[2px] text-charcoal/40 mt-6">Nathalie · Coaching</p>
        </Reveal>
      </div>

      <div class="mt-24 text-center">
        <Reveal client:load delay={0.4}>
          <a href="/reviews" class="btn-primary">Read more reviews</a>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Section 6 — About Miro -->
  <section class="py-section-y px-section-x bg-cream">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
      <div class="relative">
        <img 
          src="https://picsum.photos/seed/miro-about-teaser/1000/1200" 
          alt="Miro Kloosterman" 
          class="w-full aspect-[4/5] object-cover shadow-tactile"
          referrerpolicy="no-referrer"
        />
      </div>
      <Reveal client:load>
        <span class="label">Meet Miro</span>
        <h2 class="mb-8">The long way round.</h2>
        <p class="text-lg font-light text-charcoal/80 leading-relaxed mb-12">
          From the spotlight of Dutch television to the quiet presence of a healing room in Bali. My path was broken so it could be rebuilt with more integrity. I don't just teach these modalities—I lived them.
        </p>
        
        <div class="flex flex-wrap items-center gap-12 opacity-30 grayscale mb-12">
          <span class="font-display text-xl font-bold">Men's Health</span>
          <span class="font-display text-xl font-bold">The Rake</span>
          <span class="font-display text-xl font-bold">GTST</span>
          <span class="font-display text-xl font-bold">Story</span>
        </div>
        
        <a href="/about" class="btn-outline">Meet Miro →</a>
      </Reveal>
    </div>
  </section>

  <!-- Section 7 — Bali as Environment -->
  <section class="relative py-section-y px-section-x overflow-hidden bg-deep-forest min-h-[80vh] flex items-center">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://picsum.photos/seed/bali-landscape/1920/1080" 
        alt="Bali Landscape" 
        class="object-cover w-full h-full opacity-40"
        referrerpolicy="no-referrer"
      />
    </div>
    <div class="max-w-7xl mx-auto w-full z-10 text-center">
      <Reveal client:load>
        <h2 class="text-white text-6xl md:text-8xl mb-8">Healing has a place. That place is Bali.</h2>
        <p class="text-sand/80 text-xl font-light max-w-2xl mx-auto mb-12">
          The island's energy isn't just a backdrop—it's a participant in the work. The jungle, the water, and the ancient traditions of this land provide the container for your transformation.
        </p>
        <div class="flex flex-wrap justify-center gap-8 text-gold font-body text-[10px] font-bold uppercase tracking-[3px]">
          <span>Rice Fields</span>
          <span>Holy Water</span>
          <span>Jungle Silence</span>
          <span>Ancient Ceremony</span>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 8 — CTA / Discovery Call -->
  <section class="bg-deep-forest pt-section-y pb-16 px-section-x grain relative">
    <div class="w-full text-center">
      <div class="h-px w-32 bg-gold mx-auto mb-16"></div>
      <Reveal client:load width="100%">
        <h2 class="text-white mb-8">Ready to begin?</h2>
        <p class="text-sand/60 text-xl font-light mb-16">Start with a free 15-minute discovery call.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary !px-16 !py-6 !text-sm">Book Your Discovery Call</a>
        <p class="text-sand/30 text-[10px] uppercase tracking-[2px] mt-8">No commitment. Just a conversation.</p>
      </Reveal>
    </div>
  </section>
</Layout>

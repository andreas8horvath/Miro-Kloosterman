---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Men's Health Feature — Miro Kloosterman";
const description = "Cover shoot and feature in Men's Health magazine.";
---

<Layout title={title} description={description}>
  <section class="py-section-y px-section-x max-w-4xl mx-auto text-center">
    <Reveal client:load>
      <h1 class="text-5xl font-display mb-12">Men's Health</h1>
      <div class="aspect-[3/4] bg-linen rounded-xl mb-12 flex items-center justify-center">
        <img src="https://picsum.photos/seed/menshealth/1000/1333" alt="Men's Health Cover" class="object-cover w-full h-full rounded-xl" referrerpolicy="no-referrer" />
      </div>
      <p class="text-lg">Cover shoot and feature in Men's Health magazine.</p>
      <a href="/studio" class="btn-text mt-12 block">← Back to Studio</a>
    </Reveal>
  </section>
</Layout>

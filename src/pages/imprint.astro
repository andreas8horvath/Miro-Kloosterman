---
import Layout from '../layouts/Layout.astro';
import { Reveal } from '../components/Reveal';

const title = "Imprint — Body, Mind & Soul Therapy";
const description = "Legal imprint for Miro Kloosterman's Body, Mind & Soul Therapy.";
---

<Layout title={title} description={description}>
  <section class="bg-sand h-screen flex items-center pt-24 px-section-x">
    <div class="max-w-4xl mx-auto">
      <Reveal client:load>
        <span class="label !text-gold mb-8 block">Legal</span>
        <h1 class="mb-16">Imprint.</h1>
        <div class="space-y-12 text-lg font-light text-charcoal/80 leading-relaxed">
          <div class="space-y-4">
            <span class="label !text-gold">Service Provider</span>
            <p class="font-serif text-2xl text-deep-forest">Miro Kloosterman</p>
            <p>Body, Mind & Soul Therapy</p>
          </div>
          
          <div class="space-y-4">
            <span class="label !text-gold">Contact</span>
            <p>Email: info@mirokloosterman.com</p>
          </div>

          <div class="space-y-4">
            <span class="label !text-gold">Based in</span>
            <p>Bali, Indonesia</p>
            <p>Turkey</p>
          </div>

          <p class="mt-24 text-sm italic opacity-60">This imprint is provided for EU compliance. Full legal details to be updated by the site owner.</p>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { Reveal } from '../components/Reveal';

const title = "Reviews — Body, Mind & Soul Therapy";
const description = "What clients say about working with Miro Kloosterman. Thirty plus reviews across breathwork, bodywork, retreats, and more.";

const featuredReviews = [
  {
    name: "Christopher",
    modality: "Breathwork",
    quote: "What I experienced with Miro was beyond any description. Like I'm leaving my body and then coming back again but as a different person. It really feels like a rebirth."
  },
  {
    name: "Anna",
    modality: "Body Reset",
    quote: "After only one session, [years of neck and shoulder tension] was all gone."
  },
  {
    name: "Lina",
    modality: "Breathwork (Lithuania)",
    quote: "It really feels like I released the pain from my family's line. I have no trauma bonding with my mom anymore."
  },
  {
    name: "Maria Johanna",
    modality: "Chi Nei Tsang",
    quote: "During the first session I experienced the most intense crying in my whole life. It was grief of being a vanished twin. After this session I can say that my life shifted completely."
  },
  {
    name: "Dragonheart",
    modality: "Breathwork",
    quote: "I met many shamans, healers, coaches. He is the cleanest energy one."
  }
];

const allReviews = [
  { name: "Steven", modality: "Private Retreat", quote: "Investing time with Miro has transformed my life on multiple levels. I am now stronger, healthier, happier, and more fulfilled." },
  { name: "Jacqueline", modality: "Private Retreat", quote: "This special and gifted person is able to challenge you, to make you feel what needs to be felt. Go if you feel you have to go." },
  { name: "Wouter Blom", modality: "Private Retreat", quote: "The rest, exercise, yoga, fitness, breathing exercises, and activities gave me peace and intrinsic motivation to get out and be active." },
  { name: "Amirhossein Rezaei", modality: "Water Therapy", quote: "The anxiety I was carrying due to work-related stress completely melted away, replaced by a deep and grounding sense of calm." },
  { name: "Awa", modality: "Hypnotherapy", quote: "Our hypnotherapy sessions were deeply insightful and transformative, leaving me with more clarity and inner strength." },
  { name: "Nathalie", modality: "Coaching", quote: "You are someone with a huge passion for his profession and a great love for his coachees." }
];
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="bg-sand h-screen flex items-center pt-24 px-section-x">
    <div class="max-w-7xl mx-auto">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label">Client Experiences</span>
          <h1 class="mb-12">The word people use first is safe.</h1>
          <p class="text-xl md:text-2xl font-light text-charcoal/80 leading-relaxed">
            I've kept almost every review clients have written me over the years. Reading them back, one pattern is impossible to miss — the first thing people describe is the safety of the space.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — Featured Reviews -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto space-y-24">
      {featuredReviews.map((review, index) => (
        <Reveal client:load delay={index * 0.1}>
          <div class={`max-w-4xl mx-auto ${index % 2 === 1 ? 'lg:ml-auto lg:mr-0' : 'lg:mr-auto lg:ml-0'}`}>
            <div class="review-card">
              <blockquote class="pull-quote !text-deep-forest">"{review.quote}"</blockquote>
              <div class="mt-12 flex items-center gap-6">
                <div class="w-12 h-px bg-gold"></div>
                <div class="flex flex-col">
                  <span class="font-body text-sm font-bold uppercase tracking-[2px] text-charcoal">{review.name}</span>
                  <span class="font-body text-[10px] font-bold uppercase tracking-[2px] text-gold">{review.modality}</span>
                </div>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </section>

  <!-- Section 3 — All Reviews Grid -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {allReviews.map((review, index) => (
          <Reveal client:load delay={index * 0.05}>
            <div class="bg-cream p-12 shadow-tactile flex flex-col h-full">
              <blockquote class="font-quote italic text-lg text-charcoal/80 leading-relaxed mb-12">"{review.quote}"</blockquote>
              <div class="mt-auto flex items-center gap-4">
                <div class="w-8 h-px bg-gold/30"></div>
                <div class="flex flex-col">
                  <span class="font-body text-xs font-bold uppercase tracking-[1px] text-charcoal">{review.name}</span>
                  <span class="font-body text-[9px] font-bold uppercase tracking-[1px] text-gold">{review.modality}</span>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 4 — Closing CTA -->
  <section class="bg-deep-forest pt-section-y pb-16 px-section-x grain relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal client:load>
        <h2 class="text-white mb-8">Ready to start your own?</h2>
        <p class="text-sand/60 text-xl font-light mb-16 leading-relaxed">The work starts with a thirty-minute discovery call. No pitch, no script, no pressure.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a free discovery call</a>
      </Reveal>
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Harmonic Flow Aquatic Healing Arts — With Miro Kloosterman and Damla Yaku";
const description = "Harmonic Flow Aquatic Healing Arts. Water-based healing in three stages — above water, under water, and the return. Reaches what land-based work can't.";
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="relative h-screen flex items-center px-section-x pt-24 overflow-hidden grain bg-deep-forest">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://picsum.photos/seed/miro-water-therapy/1920/1080" 
        alt="Harmonic Flow Aquatic Healing Arts" 
        class="object-cover w-full h-full opacity-40"
        referrerpolicy="no-referrer"
      />
    </div>
    <div class="max-w-7xl mx-auto w-full z-10">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label !text-gold">Session Modality</span>
          <h1 class="text-white mb-8">Harmonic Flow Aquatic Healing Arts.</h1>
          <p class="font-body text-xl md:text-2xl font-light text-sand/80 mb-8 tracking-wide">
            Water therapy that works in three stages — above water, under water, and the return. Reaching what land-based work can't.
          </p>
          <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — The Work -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">What it is.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8 space-y-12">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
            <Reveal client:load delay={0.1}>
              <img 
                src="https://picsum.photos/seed/water-depth/800/600" 
                alt="Therapeutic underwater movement" 
                class="w-full aspect-video object-cover shadow-tactile mb-8"
                referrerpolicy="no-referrer"
              />
            </Reveal>
            <Reveal client:load delay={0.2}>
              <img 
                src="https://picsum.photos/seed/water-peace/800/600" 
                alt="Calm water healing environment" 
                class="w-full aspect-video object-cover shadow-tactile mb-8"
                referrerpolicy="no-referrer"
              />
            </Reveal>
          </div>
          <Reveal client:load delay={0.1}>
            <div class="space-y-8 text-lg font-light text-charcoal/80 leading-relaxed">
              <p>Harmonic Flow Aquatic Healing Arts is a water therapy tradition that brings together multiple lineages of water-based healing. I trained in it, and I also co-facilitate this work with my partner Damla Yaku, who carries the lineage deeply.</p>
              <p>Water does something land-based work can't. It holds you. It takes away the weight of your own body. It reaches parts of the nervous system that rarely get touched when you're standing upright. The element itself is part of the therapy.</p>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 — The three stages -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">The three stages.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8 space-y-12">
          {[
            { title: "1. Above water.", desc: "We begin at the surface. Float bands support your legs, nose clips go on, and a water pillow supports your head. The body can finally let go — most clients enter a quiet, meditative, almost theta-state kind of rest within the first few minutes." },
            { title: "2. Under water.", desc: "Short submersions at first, held in stillness. As you get comfortable, the movements become more fluid and dynamic — there's a specific kind of surrender that underwater work opens. Clients report symbolic experiences, old memories, a quality of being held that some describe as returning to the womb." },
            { title: "3. The return.", desc: "Emerging from water is metaphorically a birth, and we treat it that way. We ground the experience with breath, gentle massage, and whatever the body needs to come fully back. Aromatherapy, incense, and quiet instruments are part of this stage." }
          ].map((stage, i) => (
            <Reveal client:load delay={i * 0.1}>
              <div class="bg-sand p-12 grain">
                <span class="label !text-gold mb-6 block">{stage.title}</span>
                <p class="text-lg font-light text-charcoal/80 leading-relaxed">{stage.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4 — Practical -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">Practical.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8">
          <Reveal client:load delay={0.1}>
            <p class="text-lg font-light text-charcoal/80 leading-relaxed">
              Water therapy happens in pools, the sea, or natural water sources. The water has to be clean and at the right temperature — this matters more than people think. Every session is unique. The best thing you can do before a water session is let go of what you expect it to be.
            </p>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5 — Testimonial -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-4xl mx-auto text-center">
      <Reveal client:load>
        <blockquote class="pull-quote">
          "The anxiety I was carrying due to work-related stress completely melted away, replaced by a deep and grounding sense of calm."
        </blockquote>
        <p class="font-serif italic text-2xl text-deep-forest mt-8">— Amirhossein Rezaei</p>
      </Reveal>
    </div>
  </section>

  <!-- Section 6 — Closing CTA -->
  <section class="bg-deep-forest pt-section-y pb-16 px-section-x grain relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal client:load>
        <h2 class="text-white mb-8">Ready to flow?</h2>
        <p class="text-sand/60 text-xl font-light mb-16 leading-relaxed">The work starts with a thirty-minute discovery call. No pitch, no script, no pressure.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
      </Reveal>
    </div>
  </section>
</Layout>

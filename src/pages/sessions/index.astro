---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Individual Sessions — Breathwork, Bodywork, Water Therapy, Hypnotherapy";
const description = "Individual healing sessions with Miro Kloosterman. Breathwork, bodywork, water therapy, hypnotherapy, coaching. In-person or online.";

const sessions = [
  {
    title: "Transformative Breathwork",
    description: "Conscious connected breathing combined with bodywork, movement, and sound. Access and release what the mind can't reach on its own.",
    href: "/sessions/breathwork"
  },
  {
    title: "Body Reset Therapy",
    description: "Manual therapy based on Fixed Points Theory. Treats every joint in the body as part of a connected system. Often brings immediate relief.",
    href: "/sessions/body-reset"
  },
  {
    title: "Chi Core Release Massage",
    description: "Chi Nei Tsang — a belly and organ massage that reaches stored emotions the way nothing else does. Deep emotional release is common.",
    href: "/sessions/chi-nei-tsang"
  },
  {
    title: "Harmonic Flow Aquatic Healing Arts",
    description: "Water therapy in a pool, the sea, or a natural water source. Three stages: above water, under water, and the return.",
    href: "/sessions/water-therapy"
  },
  {
    title: "Hypnotherapy",
    description: "Online or in-person. Subconscious work for anxiety, phobias, habit change, sleep, pain, and the loops the conscious mind can't break.",
    href: "/sessions/hypnotherapy"
  },
  {
    title: "Coaching and Mentoring",
    description: "Life coaching and lifestyle coaching, grounded in twenty years of health and personal development work. Online or in-person.",
    href: "/sessions/coaching"
  }
];
---

<Layout title={title} description={description}>
  <section class="py-section-y px-section-x max-w-7xl mx-auto">
    <Reveal client:load>
      <div class="text-center mb-24">
        <span class="text-sm font-medium tracking-[0.2em] uppercase text-soil-muted mb-8 block">One-on-One Support</span>
        <h1 class="text-6xl md:text-8xl font-display mb-12 text-soil leading-tight">Individual sessions.</h1>
        <p class="text-xl md:text-2xl text-soil-muted max-w-3xl mx-auto mb-12 leading-relaxed">
          A place to start. Or a regular practice. In-person when our paths cross, or online from anywhere.
        </p>
        <p class="text-lg max-w-2xl mx-auto text-soil-muted">
          If you're not ready for a full retreat, or if you want to work with me from wherever you are, individual sessions are how most people begin. Each modality below is a different entry point into the same underlying work.
        </p>
      </div>
    </Reveal>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {sessions.map((session, index) => (
        <Reveal client:load delay={index * 0.1}>
          <div class={`service-card h-full ${index % 3 === 1 ? 'lg:translate-y-12' : ''}`}>
            <h3 class="text-3xl font-display">{session.title}</h3>
            <p class="text-soil-muted">{session.description}</p>
            <a href={session.href} class="btn-text mt-auto w-fit">Learn more</a>
          </div>
        </Reveal>
      ))}
    </div>

    <Reveal client:load>
      <div class="mt-48 bg-surface-container-low p-16 rounded-xl text-center shadow-tactile">
        <h2 class="text-4xl md:text-5xl font-display mb-8 text-soil">Not sure which session is right?</h2>
        <p class="text-xl text-soil-muted mb-12 max-w-xl mx-auto leading-relaxed">Most people aren't. That's what the discovery call is for. Tell me what's going on and I'll tell you honestly where I'd start.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a free discovery call</a>
      </div>
    </Reveal>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Modalities — Breathwork, Bodywork, Water Therapy, Hypnotherapy";
const description = "Individual healing modalities with Miro Kloosterman. Breathwork, bodywork, water therapy, hypnotherapy, coaching. In-person or online.";

const sessions = [
  {
    title: "Transformative Breathwork",
    description: "Conscious connected breathing combined with bodywork, movement, and sound. Access and release what the mind can't reach on its own.",
    href: "/sessions/breathwork"
  },
  {
    title: "Body Reset Therapy",
    description: "Manual therapy based on Fixed Points Theory. Treats every joint in the body as part of a connected system. Often brings immediate relief.",
    href: "/sessions/body-reset"
  },
  {
    title: "Chi Core Release Massage",
    description: "Chi Nei Tsang — a belly and organ massage that reaches stored emotions the way nothing else does. Deep emotional release is common.",
    href: "/sessions/chi-nei-tsang"
  },
  {
    title: "Harmonic Flow Aquatic Healing Arts",
    description: "Water therapy in a pool, the sea, or a natural water source. Three stages: above water, under water, and the return.",
    href: "/sessions/water-therapy"
  },
  {
    title: "Hypnotherapy",
    description: "Online or in-person. Subconscious work for anxiety, phobias, habit change, sleep, pain, and the loops the conscious mind can't break.",
    href: "/sessions/hypnotherapy"
  },
  {
    title: "Coaching and Mentoring",
    description: "Life coaching and lifestyle coaching, grounded in twenty years of health and personal development work. Online or in-person.",
    href: "/sessions/coaching"
  }
];
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="bg-sand h-screen flex items-center pt-24 px-section-x">
    <div class="max-w-7xl mx-auto">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label">One-on-One Support</span>
          <h1 class="mb-12">Modalities.</h1>
          <p class="text-xl md:text-2xl font-light text-charcoal/80 leading-relaxed">
            A place to start. Or a regular practice. In-person when our paths cross, or online from anywhere.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — Sessions Grid -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sessions.map((session, index) => (
          <Reveal client:load delay={index * 0.1} className="h-full">
            <a href={session.href} class="service-card group h-full">
              <h3 class="text-white group-hover:text-gold transition-colors">{session.title}</h3>
              <p class="text-sand/60 font-light text-sm leading-relaxed">{session.description}</p>
              <span class="btn-text !text-gold mt-auto">Learn more →</span>
            </a>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3 — Closing CTA -->
  <section class="bg-deep-forest py-section-y px-section-x grain relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal client:load>
        <h2 class="text-white mb-8">Not sure which session is right?</h2>
        <p class="text-sand/60 text-xl font-light mb-16 leading-relaxed">Most people aren't. That's what the discovery call is for. Tell me what's going on and I'll tell you honestly where I'd start.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a free discovery call</a>
      </Reveal>
    </div>
  </section>
</Layout>

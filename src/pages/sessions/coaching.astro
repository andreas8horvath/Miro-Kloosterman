---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Coaching and Mentoring — With Miro Kloosterman";
const description = "Life, lifestyle, and health coaching with twenty years of experience. Individual sessions, ongoing mentoring, workshops, and group training. Online or in-person.";
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="relative h-screen flex items-center px-section-x pt-24 overflow-hidden grain bg-deep-forest">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://picsum.photos/seed/miro-coaching/1920/1080" 
        alt="Coaching and Mentoring" 
        class="object-cover w-full h-full opacity-40"
        referrerpolicy="no-referrer"
      />
    </div>
    <div class="max-w-7xl mx-auto w-full z-10">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label !text-gold">Session Modality</span>
          <h1 class="text-white mb-8">Coaching and Mentoring.</h1>
          <p class="font-body text-xl md:text-2xl font-light text-sand/80 mb-8 tracking-wide">
            Twenty years of health, lifestyle, and personal development work — in one conversation at a time.
          </p>
          <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — The Work -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">What it is.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8 space-y-12">
          <Reveal client:load delay={0.1}>
            <div class="space-y-8 text-lg font-light text-charcoal/80 leading-relaxed">
              <p>I've been a certified life coach since 2001. Over twenty years of working with people on what keeps them stuck — sometimes it's their body, sometimes it's their habits, sometimes it's the story they're telling themselves about what's possible.</p>
              <p>Coaching sessions are available one-on-one, in-person when our paths cross, or online from anywhere. I also run workshops and group training for businesses, schools, and organisations on request.</p>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 — What we work on -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">What we work on.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8 space-y-12">
          {[
            { title: "Lifestyle and health", desc: "Sustainable changes that actually hold. Nutrition, movement, sleep, daily rhythm, stress patterns. I work with vegan and plant-based clients as well as clients transitioning toward that." },
            { title: "Personal growth", desc: "Self-awareness, habit change, patterns that keep repeating, the gap between where you are and where you're trying to get." },
            { title: "Integration", desc: "After a retreat, a breathwork intensive, a period of deep work — what do you actually do with what moved? How do you carry it into daily life without losing it?" },
            { title: "Direction", desc: "When you know something needs to change but don't yet know what." }
          ].map((item, i) => (
            <Reveal client:load delay={i * 0.1}>
              <div>
                <span class="label !text-gold">{item.title}</span>
                <p class="text-lg font-light text-charcoal/80 leading-relaxed mt-4">{item.desc}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4 — Workshops -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-4">
          <Reveal client:load>
            <h2 class="sticky top-32">Workshops and group training.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-8">
          <Reveal client:load delay={0.1}>
            <p class="text-lg font-light text-charcoal/80 leading-relaxed">
              I also run workshops for businesses, schools, and other organisations on topics including stress and burnout, breathwork basics, lifestyle foundations, and integrated wellbeing. These are custom-built for the group.
            </p>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5 — Testimonial -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-4xl mx-auto text-center">
      <Reveal client:load>
        <blockquote class="pull-quote">
          "You are someone with a huge passion for his profession and a great love for his coachees. I recognize myself very well in your metaphor of the butterfly. Time to shine, Miro."
        </blockquote>
        <p class="font-serif italic text-2xl text-deep-forest mt-8">— Nathalie</p>
      </Reveal>
    </div>
  </section>

  <!-- Section 6 — Closing CTA -->
  <section class="bg-deep-forest pt-section-y pb-16 px-section-x grain relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal client:load>
        <h2 class="text-white mb-8">Ready to talk?</h2>
        <p class="text-sand/60 text-xl font-light mb-16 leading-relaxed">The work starts with a thirty-minute discovery call. No pitch, no script, no pressure.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
      </Reveal>
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { Reveal } from '../../components/Reveal';

const title = "Body Reset Therapy — With Miro Kloosterman";
const description = "Body Reset Therapy — manual therapy treating every joint as part of a connected system. Often brings immediate relief from chronic pain and migraines.";
---

<Layout title={title} description={description}>
  <!-- Section 1 — Hero -->
  <section class="relative h-screen flex items-center px-section-x pt-24 overflow-hidden grain bg-deep-forest">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://picsum.photos/seed/miro-body-reset/1920/1080" 
        alt="Body Reset Therapy" 
        class="object-cover w-full h-full opacity-40"
        referrerpolicy="no-referrer"
      />
    </div>
    <div class="max-w-7xl mx-auto w-full z-10">
      <Reveal client:load>
        <div class="max-w-3xl">
          <span class="label !text-gold">Session Modality</span>
          <h1 class="text-white mb-8">Body Reset Therapy.</h1>
          <p class="font-body text-xl md:text-2xl font-light text-sand/80 mb-8 tracking-wide">
            Manual therapy based on Fixed Points Theory. Treating every joint as part of a single connected system.
          </p>
          <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- Section 2 — The Work -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-5">
          <Reveal client:load>
            <h2 class="sticky top-32">What it is.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-7 space-y-12">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
            <Reveal client:load delay={0.1}>
              <img 
                src="https://picsum.photos/seed/bodywork-one/800/600" 
                alt="Precision joint alignment" 
                class="w-full aspect-video object-cover shadow-tactile mb-8"
                referrerpolicy="no-referrer"
              />
            </Reveal>
            <Reveal client:load delay={0.2}>
              <img 
                src="https://picsum.photos/seed/bodywork-two/800/600" 
                alt="Restorative therapeutic touch" 
                class="w-full aspect-video object-cover shadow-tactile mb-8"
                referrerpolicy="no-referrer"
              />
            </Reveal>
          </div>
          <Reveal client:load delay={0.1}>
            <p class="text-lg font-light text-charcoal/80 leading-relaxed">
              A restriction in one joint almost always creates compensation somewhere else, and that compensation is usually where the pain finally shows up. I work through the whole body, joint by joint, by hand. The first session often brings a shift people haven't felt in years.
            </p>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3 — What it addresses -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-5">
          <Reveal client:load>
            <h2 class="sticky top-32">What it addresses.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-7">
          <Reveal client:load delay={0.1}>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {[
                "Back, hip, knee, ankle, foot pain",
                "Shoulder, elbow, wrist, and neck pain",
                "Pelvic instability, hernias, whiplash, RSI",
                "Migraines and cluster headaches",
                "Ménière's disease, sinus issues",
                "Asthma, hay fever",
                "Spastic intestinal problems",
                "Menstrual pain, restless legs",
                "Unexplained fatigue",
                "Emotional instability and depression",
                "Scoliosis in children (from age five)"
              ].map(item => (
                <div class="flex items-center gap-4">
                  <div class="w-2 h-2 bg-gold rotate-45 flex-shrink-0"></div>
                  <span class="font-body text-sm font-light text-charcoal">{item}</span>
                </div>
              ))}
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4 — Treatment rhythm -->
  <section class="bg-sand py-section-y px-section-x">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24">
        <div class="lg:col-span-5">
          <Reveal client:load>
            <h2 class="sticky top-32">Treatment rhythm.</h2>
          </Reveal>
        </div>
        <div class="lg:col-span-7">
          <Reveal client:load delay={0.1}>
            <p class="text-lg font-light text-charcoal/80 leading-relaxed">
              The first session can initiate a big change. A second session usually follows three to four weeks later. After that the intervals stretch out — most clients use it as an ongoing preventative practice, not a one-time fix.
            </p>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5 — Testimonial -->
  <section class="bg-cream py-section-y px-section-x">
    <div class="max-w-4xl mx-auto text-center">
      <Reveal client:load>
        <blockquote class="pull-quote">
          "After only one session, [years of neck and shoulder tension] was all gone."
        </blockquote>
        <p class="font-serif italic text-2xl text-deep-forest mt-8">— Anna</p>
      </Reveal>
    </div>
  </section>

  <!-- Section 6 — Closing CTA -->
  <section class="bg-deep-forest pt-section-y pb-16 px-section-x grain relative">
    <div class="max-w-3xl mx-auto text-center">
      <Reveal client:load>
        <h2 class="text-white mb-8">Ready to reset?</h2>
        <p class="text-sand/60 text-xl font-light mb-16 leading-relaxed">The work starts with a thirty-minute discovery call. No pitch, no script, no pressure.</p>
        <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary">Book a Discovery Call</a>
      </Reveal>
    </div>
  </section>
</Layout>

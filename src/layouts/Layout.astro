---
import '../index.css';
import { getDomainInfo } from '../lib/domain';
import { CookieBanner } from '../components/CookieBanner';
import { NewsletterPopup } from '../components/NewsletterPopup';
import { MobileMenu } from '../components/MobileMenu';

interface Props {
	title: string;
	description: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { title, description, hideNav = false, hideFooter = false } = Astro.props;
const host = ''; // Static build
const { siteName } = getDomainInfo(host);

const navItems = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { 
    name: 'Retreats', 
    href: '/retreats',
    children: [
      { name: 'Private Retreats', href: '/retreats/private' },
      { name: 'Group Retreats', href: '/retreats/group' },
    ]
  },
  { 
    name: 'Modalities', 
    href: '/sessions',
    children: [
      { name: 'Breathwork', href: '/sessions/breathwork' },
      { name: 'Body Reset', href: '/sessions/body-reset' },
      { name: 'Chi Nei Tsang', href: '/sessions/chi-nei-tsang' },
      { name: 'Water Therapy', href: '/sessions/water-therapy' },
      { name: 'Hypnotherapy', href: '/sessions/hypnotherapy' },
      { name: 'Coaching', href: '/sessions/coaching' },
    ]
  },
  { name: 'Reviews', href: '/reviews' },
  { name: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

    <!-- SEO -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
	</head>
	<body class="bg-sand text-charcoal font-body antialiased selection:bg-gold/20">
    {!hideNav && (
      <nav class="fixed top-0 left-0 w-full z-50 bg-sand/80 backdrop-blur-md transition-all duration-500">
      <div class="max-w-7xl mx-auto px-section-x">
        <div class="flex justify-between h-24 items-center">
          <div class="flex-shrink-0">
            <a href="/" class="font-display text-2xl text-deep-forest tracking-tight uppercase font-bold">{siteName}</a>
          </div>
          <div class="hidden lg:block">
            <div class="flex items-center space-x-12">
              {navItems.map(item => (
                <div class="relative group">
                  <a href={item.href} class="nav-link flex items-center gap-1">
                    {item.name}
                    {item.children && (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    )}
                  </a>
                  {item.children && (
                    <div class="absolute left-0 top-full pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                      <div class="bg-cream shadow-tactile p-6 min-w-[200px] flex flex-col gap-4">
                        {item.children.map(child => (
                          <a href={child.href} class="font-body text-[10px] font-bold uppercase tracking-[2px] text-deep-forest hover:text-gold transition-colors">
                            {child.name}
                          </a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
          <div class="lg:hidden">
            <MobileMenu client:load navItems={navItems} siteName={siteName} />
          </div>
        </div>
      </div>
    </nav>
    )}

		<main>
			<slot />
		</main>

    <CookieBanner client:load />
    <NewsletterPopup client:load />

    {!hideFooter && (
      <footer class="bg-deep-forest text-sand pt-16 pb-16 px-section-x relative overflow-hidden grain">
      <div class="max-w-7xl mx-auto">
        <div class="h-px w-full bg-gold/30 mb-16"></div>
        
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24">
          <div class="lg:col-span-4">
            <a href="/" class="font-display text-3xl text-white tracking-tight uppercase font-bold mb-8 block">{siteName}</a>
            <p class="text-sand/60 max-w-sm">Body, Mind & Soul Therapy. Available worldwide.</p>
          </div>
          
          <div class="lg:col-span-5 grid grid-cols-2 gap-8">
            <div>
              <span class="label text-gold/60">Navigate</span>
              <ul class="space-y-4">
                {navItems.map(item => (
                  <li><a href={item.href} class="text-sm hover:text-gold transition-colors">{item.name}</a></li>
                ))}
              </ul>
            </div>
            <div>
              <span class="label text-gold/60">Modalities</span>
              <ul class="space-y-4">
                <li><a href="/sessions/breathwork" class="text-sm hover:text-gold transition-colors">Breathwork</a></li>
                <li><a href="/sessions/body-reset" class="text-sm hover:text-gold transition-colors">Body Reset</a></li>
                <li><a href="/sessions/chi-nei-tsang" class="text-sm hover:text-gold transition-colors">Chi Nei Tsang</a></li>
                <li><a href="/sessions/water-therapy" class="text-sm hover:text-gold transition-colors">Water Therapy</a></li>
                <li><a href="/sessions/hypnotherapy" class="text-sm hover:text-gold transition-colors">Hypnotherapy</a></li>
                <li><a href="/sessions/coaching" class="text-sm hover:text-gold transition-colors">Coaching</a></li>
              </ul>
            </div>
          </div>

          <div class="lg:col-span-3">
            <span class="label text-gold/60">Contact</span>
            <p class="text-sm mb-8">info@mirokloosterman.com</p>
            <a href="https://tidycal.com/miro-kloosterman/15-minute-meeting" class="btn-primary w-full">Book a discovery call</a>
          </div>
        </div>

        <div class="flex flex-col md:flex-row justify-between items-center gap-8 pt-12 border-t border-white/5 text-[10px] uppercase tracking-[2px] text-sand/40">
          <div class="text-center md:text-left">
            <p>© {siteName} · Body, Mind & Soul Therapy</p>
            <p class="mt-2">Also at bodymindandsoultherapy.com</p>
          </div>
          <div class="flex gap-8">
            <a href="/cookies" class="hover:text-gold transition-colors">Cookies</a>
            <a href="/privacy" class="hover:text-gold transition-colors">Privacy</a>
            <a href="/imprint" class="hover:text-gold transition-colors">Imprint</a>
          </div>
        </div>
      </div>
    </footer>
    )}
	</body>
</html>
